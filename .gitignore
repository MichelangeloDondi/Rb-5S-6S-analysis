# Generated outputs: results/ IS committed (small, ~180 KB) so the README's
# claims are verifiable without a run (review round 3). Regenerate with the
# scripts; the committed copy is the documented run. Only the huge raw QC dump
# stays out.
results/qc_metrics.csv

# Python
__pycache__/
*.pyc
*.egg-info/
.pytest_cache/
.venv/

# macOS
.DS_Store

# source-literature PDFs (possibly copyrighted): keep the index + bib, not the PDFs
PDF_papers/

# reference-setup lab photos (carry equipment serials + a purchaser name): keep
# the transcription/notes, not the images, out of the public repo
docs/reference_setup/photos/*
!docs/reference_setup/photos/DROP_PHOTOS_HERE.md

# Personal / correspondence working files kept in the tree for convenience but
# never published. These were previously protected only by .git/info/exclude,
# which is local to one clone and does not travel — so a fresh clone elsewhere
# had no protection at all. Patterns are deliberately generic.
# tests/test_repo_hygiene.py fails if any of these ever becomes tracked.
docs/brief_*
docs/*audit*
docs/*red_team*
docs/CV_*
docs/PAPERS_PORTFOLIO.md
# manuscript drafts: unfinished prose with [X] placeholders, not results
docs/PAPER1_SKELETON.md
docs/paper1/
docs/*inquiry*
docs/linkedin*
*.docx

# reference PDFs dropped into docs are never published
docs/apparatus/*.pdf
docs/*.pdf
